---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import LogoStrip from "../components/LogoStrip.astro";
import Expertise from "../components/Expertise.astro";
import Experience from "../components/Experience.astro";
import Projects from "../components/Projects.astro";
import Writing from "../components/Writing.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";
import { profile } from "../data/profile";
import { siteConfig } from "../data/site";

const structuredData = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "ProfilePage",
      "@id": `${siteConfig.url}/#profile`,
      url: `${siteConfig.url}/`,
      mainEntity: {
        "@id": `${siteConfig.url}/#person`,
      },
      description: siteConfig.description,
    },
    {
      "@type": "Person",
      "@id": `${siteConfig.url}/#person`,
      name: profile.name,
      jobTitle: profile.role,
      description: profile.summary,
      url: `${siteConfig.url}/`,
      sameAs: siteConfig.social
        .filter((item) => item.name !== "email")
        .map((item) => item.url),
      homeLocation: {
        "@type": "Country",
        name: profile.location,
      },
    },
  ],
};
---

<BaseLayout structuredData={structuredData}>
  <Header />
  <main id="main-content">
    <Hero />
    <LogoStrip />
    <Expertise />
    <Experience />
    <Projects />
    <Writing />
    <Contact />
  </main>
  <Footer />
</BaseLayout>