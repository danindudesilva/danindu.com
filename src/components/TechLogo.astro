---
type Props = {
  name: string;
  src: string;
  alt: string;
  scale?: number;
};

const { name, src, alt, scale = 1 } = Astro.props;
---

<div class="tech-logo" aria-label={name}>
  <div class="tech-logo-shape">
    <img
      src={src}
      alt={alt}
      class="tech-logo-mark"
      loading="lazy"
      style={`transform: scale(${scale});`}
    />
  </div>
  <span class="tech-logo-label">{name}</span>
</div>