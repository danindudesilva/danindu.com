---
import { profile } from "../data/profile";
import { siteConfig } from "../data/site";
---

<section id="about" class="section hero-section">
  <div class="container hero-grid">
    <div class="hero-copy">
      <div class="eyebrow">{profile.role}</div>

      <h1 class="hero-title">
        {profile.tagline}
      </h1>

      <p class="hero-summary">
        {profile.summary}
      </p>

      <div class="hero-actions">
        <a class="button button-primary" href="#projects">View Projects</a>
        <a class="button" href={siteConfig.cta.resume} target="_blank" rel="noreferrer">
          Download CV
        </a>
        <a class="button" href="#contact">Contact Me</a>
      </div>
    </div>

    <aside class="section-card hero-panel">
      <div class="hero-panel-grid">
        <div>
          <p class="hero-panel-label">Name</p>
          <p class="hero-panel-value">{profile.name}</p>
        </div>

        <div>
          <p class="hero-panel-label">Location</p>
          <p class="hero-panel-value">{profile.location}</p>
        </div>

        <div>
          <p class="hero-panel-label">Availability</p>
          <p class="hero-panel-value">{profile.availability}</p>
        </div>

        <div>
          <p class="hero-panel-label">Focus</p>
          <div class="tech-badges">
            {profile.technologies.map((item) => (
              <span class="tech-badge">
                <span class="tech-badge-dot" aria-hidden="true"></span>
                {item}
              </span>
            ))}
          </div>
        </div>
      </div>
    </aside>
  </div>
</section>