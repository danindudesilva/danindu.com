---
import Section from "./Section.astro";
import Icon from "./Icon.astro";
import { siteConfig } from "../data/site";
---

<Section
  id="contact"
  eyebrow="Contact"
  title="Let’s connect"
  copy="I’m open to software engineering opportunities and selected freelance backend work."
>
  <div class="section-card" style="padding: 1.5rem;">
    <p style="margin-top: 0; color: var(--text-muted); max-width: 58ch;">
      Whether you’re hiring for a software engineering role or looking for help with backend systems and integrations, I’d be glad to hear from you.
    </p>

    <div style="display: flex; gap: 1rem; flex-wrap: wrap; margin-top: 1rem;">
      {
        siteConfig.social.map((item) => (
          <a class={item.name === "email" ? "button button-primary": "button"} href={item.url}>
            <Icon name={item.name} />
            {item.label}
          </a>
        ))
      }
    </div>
  </div>
</Section>