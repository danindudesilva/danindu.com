---
import Section from "./Section.astro";
import { siteConfig } from "../data/site";
import { profile } from "../data/profile";
---

<Section
  id="contact"
  eyebrow="Contact"
  title="Let’s connect"
  copy={profile.availability}
>
  <div class="section-card" style="padding: 1.5rem;">
    <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
      <a class="button button-primary" href={siteConfig.social.email}>Email</a>
      <a class="button" href={siteConfig.social.linkedin}>LinkedIn</a>
      <a class="button" href={siteConfig.social.github}>GitHub</a>
      <a class="button" href={siteConfig.cta.resume}>Download CV</a>
    </div>
  </div>
</Section>