---
import Section from "./Section.astro";
import { experience } from "../data/experience";
---

<Section
  id="experience"
  eyebrow="Experience"
  title="Selected experience"
  copy="A focused view of roles and work that best reflect my engineering strengths."
>
  <div class="grid">
    {
      experience
        .filter((item) => item.featured !== false)
        .map((item) => (
          <article class="section-card" style="padding: 1.5rem;">
            <div style="display: flex; justify-content: space-between; gap: 1rem; flex-wrap: wrap;">
              <div>
                <h3 style="margin: 0;">{item.role}</h3>
                <p style="margin: 0.25rem 0 0; color: var(--text-muted);">{item.company}</p>
              </div>
              <p style="margin: 0; color: var(--text-muted);">{item.period}</p>
            </div>

            <p>{item.summary}</p>

            <ul>
              {item.bullets.map((bullet) => <li>{bullet}</li>)}
            </ul>

            <div>
            <p style="margin: 0 0 0.5rem; color: var(--text-muted); font-size: 0.95rem;"></p>
            <div class="tech-badges">
                {item.technologies.map((item) => (
                    <span class="tech-badge">
                    <span class="tech-badge-dot" aria-hidden="true"></span>
                    {item}
                    </span>
                ))}
            </div>
            </div>
          </article>
        ))
    }
  </div>
</Section>