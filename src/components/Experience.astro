---
import Section from "./Section.astro";
import { experience } from "../data/experience";
---

<Section
  id="experience"
  eyebrow="Experience"
  title="Selected experience"
  copy="Selected roles and work that reflect my experience building production systems across fintech, cloud, and connected technology."
>
  <div class="grid">
    {
      experience
        .filter((item) => item.featured !== false)
        .map((item) => (
          <article class="section-card" style="padding: 1.5rem;">
            <div style="display: flex; justify-content: space-between; gap: 1rem; flex-wrap: wrap; align-items: baseline;">
              <div>
                <h3 style="margin: 0;">{item.role}</h3>
                <p style="margin: 0.3rem 0 0; color: var(--text-muted); font-weight: 600;">
                  {item.company}
                </p>
              </div>
              <p style="margin: 0; color: var(--text-muted); font-size: 0.95rem;">{item.period}</p>
            </div>

            <p style="margin: 1rem 0 0; color: var(--text-muted);">
              {item.summary}
            </p>

            <ul style="margin: 1rem 0 0; padding-left: 1.2rem;">
              {item.bullets.map((bullet) => (
                <li style="margin-bottom: 0.65rem;">{bullet}</li>
              ))}
            </ul>

            <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; margin-top: 1rem;">
              {item.technologies.map((tech) => (
                <span class="tech-badge">
                  <span class="tech-badge-dot" aria-hidden="true"></span>
                  {tech}
                </span>
              ))}
            </div>
          </article>
        ))
    }
  </div>
</Section>