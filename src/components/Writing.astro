---
import Section from "./Section.astro";
import Icon from "./Icon.astro";
import { featuredWriting } from "../data/writing";
---

<Section
  id="writing"
  eyebrow="Writing"
  title="Technical writing and notes"
  copy="A small selection of engineering writing that reflects how I communicate technical ideas and practical solutions."
>
  <div class="grid grid-2">
    {
      featuredWriting.map((item) => (
        <article class="section-card" style="padding: 1.25rem;">
          <p style="margin: 0 0 0.4rem; color: var(--accent); font-size: 0.9rem; font-weight: 600;">
            {item.platform}
          </p>

          <h3 style="margin: 0 0 0.5rem;">{item.title}</h3>

          <p style="margin: 0; color: var(--text-muted);">
            {item.description}
          </p>

          <p style="margin: 0.9rem 0 0; color: var(--text-muted); font-size: 0.95rem;">
            {item.date}
          </p>

          <div style="margin-top: 1rem;">
            <a class="button" href={item.url} target="_blank" rel="noreferrer">
              <Icon name="medium" />
              Read Article
            </a>
          </div>
        </article>
      ))
    }
  </div>
</Section>